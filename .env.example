# MAIP v5.0 — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to Git

# Required — get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Daily token budget across all users (default: 500,000)
DAILY_TOKEN_BUDGET=500000

# Maximum file upload size in MB (default: 20)
MAX_FILE_SIZE_MB=20

# Session expiry in hours (default: 4)
SESSION_EXPIRY_HOURS=4

# Comma-separated allowed origins for CORS
# Set to your deployed domain in production
ALLOWED_ORIGINS=http://localhost:8000
